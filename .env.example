# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Neptune Configuration
NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xxxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=your-opensearch-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=healthcare-knowledge

# Bedrock Configuration
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# S3 Configuration
S3_BUCKET=rhisa-healthcare-data
S3_PREFIX=knowledge-base/

# Application Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
PORT=5000
LOG_LEVEL=INFO

# GraphRAG Configuration
INGEST_DATA=false
ENABLE_CACHE=true
MAX_GRAPH_HOPS=3
MAX_VECTOR_RESULTS=10

# Lambda Configuration (for deployment)
LAMBDA_TIMEOUT=300
LAMBDA_MEMORY=1024

# API Gateway Configuration
API_GATEWAY_STAGE=prod

# CloudWatch Configuration
LOG_GROUP=/aws/lambda/rhisa-graphrag
